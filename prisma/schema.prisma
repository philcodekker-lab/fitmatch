// Prisma schema for the PT Marketplace MVP.
//
// Postgres is the default. SQLite has no native enum support, so enum-like
// fields and arrays are stored as JSON-encoded strings — the helpers in
// src/lib/profile.js decode them on the way out.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   // "PT" | "ADMIN"
  createdAt    DateTime @default(now())

  trainerProfile TrainerProfile?
}

model TrainerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  bio          String   @default("")
  caseStudies  String   @default("")
  currentOffer String   @default("")

  specialisms      String @default("[]")
  trainingStyles   String @default("[]")
  experienceLevels String @default("[]")

  priceMin     Int      @default(0)
  priceMax     Int      @default(0)

  location     String   @default("")

  // Media + socials
  photoUrl         String?
  socialInstagram  String   @default("")
  socialTiktok     String   @default("")
  socialFacebook   String   @default("")
  socialWebsite    String   @default("")
  caseStudyMedia   String   @default("[]")

  // Practice details (Phase 2 — promoted from UI stubs)
  responseTimeHours Int     @default(24)
  acceptingClients  Boolean @default(true)
  credentials       String  @default("[]")   // JSON array of strings
  pricingTiers      String  @default("{}")   // JSON {single, sixPack, twelvePack, monthlyOnline}
  weeklySchedule    String  @default("[]")   // JSON array of {label, intensity}
  languages         String  @default("[]")   // JSON array of strings
  gymLocations      String  @default("[]")   // JSON array of strings

  approved     Boolean  @default(false)
  featured     Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
