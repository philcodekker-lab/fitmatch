# Copy to `.env` and adjust as needed.

# Postgres connection string. For Neon, Supabase, etc. it looks like:
#   postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# For a local Postgres:
#   postgresql://postgres:postgres@localhost:5432/fitmatch
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Used to sign auth cookies. Use a long random string in production.
# Generate with:  openssl rand -base64 48
AUTH_SECRET="dev-secret-please-change-me-in-production-32chars+"
